{
  "buildCommand": "node scripts/build-static.js",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/crm/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/app.js",
      "destination": "/assets/client.js"
    },
    {
      "source": "/client.js",
      "destination": "/assets/client.js"
    },
    {
      "source": "/crm",
      "destination": "/index.html"
    },
    {
      "source": "/zabory-iz-profnastila",
      "destination": "/public/zabory-iz-profnastila.html"
    },
    {
      "source": "/kalkulyator-zabora",
      "destination": "/public/kalkulyator-zabora.html"
    }
  ]
}
